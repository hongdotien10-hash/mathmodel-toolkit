# ============================================================
# MathModel Toolkit — API 配置文件
# ============================================================
# 复制此文件为 .env，填入你的 API Key 即可使用 AI 增强功能
#   cp api/.env.example .env
#
# 默认使用 DeepSeek V4 Pro (deepseek-reasoner)，性价比最高
# 也支持 OpenAI / Anthropic / 智谱 / 通义千问 / Kimi / 自定义
# ============================================================

# --- DeepSeek（默认推荐）---
# 获取 Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# --- OpenAI（可选）---
# 获取 Key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Anthropic Claude（可选）---
# 获取 Key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- 智谱 GLM（可选）---
# 获取 Key: https://open.bigmodel.cn/
# ZHIPU_API_KEY=your-zhipu-key

# --- 通义千问（可选）---
# 获取 Key: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-your-dashscope-key

# --- Kimi / Moonshot（可选）---
# 获取 Key: https://platform.moonshot.cn/
# MOONSHOT_API_KEY=sk-your-moonshot-key

# --- 通用（覆盖上述所有）---
# LLM_API_KEY=sk-your-key

# ============================================================
# 使用说明
# ============================================================
# 1. 取消你要用的那一行的注释（删除行首的 #）
# 2. 替换 "your-xxx-key-here" 为你的真实 Key
# 3. 默认使用 DeepSeek V4 Pro (deepseek-reasoner)
#
# Python 代码中使用:
#   from api import AIAnalyzer
#   analyzer = AIAnalyzer()  # 自动读取 .env
#
# 或显式指定:
#   from api.config import APIConfig
#   from api import AIAnalyzer
#   config = APIConfig(provider="deepseek", api_key="sk-xxx")
#   analyzer = AIAnalyzer(config)
# ============================================================
