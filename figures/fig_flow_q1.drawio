        </mxCell>
        
        <!-- Validation -->
        <mxCell id="valid" value="&lt;b&gt;验证&lt;/b&gt;&lt;br&gt;✓ 14个地点全覆盖&lt;br&gt;✓ 回路闭合&lt;br&gt;✓ 582km匹配标准答案(误差&lt;1%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="100" y="660" width="300" height="60" as="geometry"/>
